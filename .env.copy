# LLM Provider Configuration
# Single provider or comma-separated list
LLM_PROVIDERS=anthropic,openai,perplexity
# Or use single provider:
# LLM_PROVIDER=openai

# API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
PERPLEXITY_API_KEY=your-perplexity-api-key-here

# Model Configuration (optional - defaults are provided)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_MODEL=sonar-pro

# Intel Source URL (optional - has default)
INTEL_URL=https://cloud.google.com/blog/topics/threat-intelligence/data-theft-salesforce-instances-via-salesloft-drift

# Rule Format: spl, sigma, or both
RULE_FORMAT=spl

# Debug mode (optional)
DEBUG=false
